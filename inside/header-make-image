DOCK_USER=$1
DOCK_PASS=$2
DOCK_UID=$3
DOCK_GID=$4
VSCODE_COMMIT=$5

# Для обнаружения кеширующего прокси на хосте
ln -s $COMMON_INSIDE_PATH/01proxy /etc/apt/apt.conf.d/
ln -s $COMMON_INSIDE_PATH/apt-proxy-checker.sh /etc/apt/

# Переменные окружения
ln -sf $INSIDE_PATH/environment /etc/
source /etc/environment

apt update

DEBIAN_FRONTEND=noninteractive apt install -yqq $(cat $COMMON_INSIDE_PATH/packages-list.txt)
